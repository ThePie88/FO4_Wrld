# =============================================================================
# FO4_Wrld — .gitignore
# Rule of thumb: only commit OUR code + analysis. Never commit Bethesda IP,
# third-party emulators with separate licenses, or large regenerable artifacts.
# =============================================================================

# -- Bethesda binaries / data files (IP, never push) --------------------------
**/Fallout4.exe
**/Fallout4Launcher.exe
**/Fallout4Custom.ini
**/Fallout4Prefs.ini
**/*.ba2
# save files (user data + game state)
**/*.fos
# backup saves
**/*.bak
# second-instance install copy (full Bethesda binary)
/FO4_b/
FO4_b/**
re/Fallout4.exe*
re/Fallout4.exe.unpacked

# -- Claude Code session data (per-user, regeneratable) ----------------------
.claude/
.claude/**

# -- Manual ops + scratch state files ----------------------------------------
.manual_ops_*.offset
# personal absolute paths
tool-paths.txt

# -- Submodules / nested git repos (vendored deps) ---------------------------
fw_native/deps/MinHook/
tools/PIEassetDecompiler/

# -- IDA Pro databases (proprietary format, hundreds of MB, regenerable) ------
*.i64
*.idb
*.id0
*.id1
*.id2
*.nam
*.til
*.til*

# -- Goldberg / SteamCMD / Steam emulators (third-party, separate licenses) ---
goldberg/
steamcmd/
**/steam_settings/
**/steam_api64.dll
**/steamclient*.dll
**/ColdClientLoader.exe
**/ColdAPI/

# -- Build artifacts (regenerable from CMake/build.bat) -----------------------
**/build/
**/CMakeCache.txt
**/CMakeFiles/
**/*.obj
**/*.lib
**/*.exp
**/*.pdb
**/*.ilk
**/*.dll
**/*.exe
# but keep build/deploy scripts
!**/*.bat
**/CMakeUserPresets.json

# Vendored deps that are submodules / fetchable separately
fw_native/deps/MinHook/build/
fw_native/deps/MinHook/.git/

# -- Python (cache + venv + dist) --------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
*.egg-info/
dist/
.pytest_cache/

# -- Runtime logs (regenerable, may contain runtime addresses or save state) -
*.log
fw_native.log
m7_trace.log
run.log

# -- Large RE intermediate files (regenerable from IDA scripts) --------------
re/_*_raw.log
re/_*_raw*.log
re/_*.dump.log
re/_ida_*.log
re/_anim_graph_m7_raw*.log
re/_bone_drive_correct[2-9]*.log

# -- IDE / OS --------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# -- Local config / secrets --------------------------------------------------
fw_config.ini
*.env
.env.*
secrets/
**/auth.token

# -- F4SE / mod manager runtime files ----------------------------------------
**/F4SE/
**/Data/F4SE/
**/Data/Scripts/Source/Temp/

# -- Frida runtime artifacts (state.json etc) -------------------------------
frida/*.frida
frida/*.cache

# -- TTD (Time Travel Debugging) artifacts -----------------------------------
# Local WinDbg TTD CLI binaries (extracted from Microsoft Store package —
# Microsoft EULA restricts redistribution; user must install WinDbg locally).
ttd_local/
# 1-10GB TTD recording files. Regenerable on demand.
ttd_traces/

# -- Game asset cache (Bethesda IP — extracted .nif/.bgsm/.dds, never push) --
fw_native/assets/raw/Meshes/
fw_native/assets/raw/Materials/
fw_native/assets/raw/Sound/
fw_native/assets/raw/Textures/

# -- Server runtime state snapshots (regenerable, contains in-game state) ----
net/state_snapshot.json*

# -- Tools binaries (we don't ship these in repo) ---------------------------
tools/*.exe

# -- BAE / archive2 / etc. (extracted assets) -------------------------------
BAE/
ALTRE-AI/
re_unpacked/
re/cache/

# -- patch test / scratch files ---------------------------------------------
patch_*.py
setup_fo4_b*.py

# -- one-off launcher tools --------------------------------------------------
FoM.exe

# -- raw demo capture (full uncompressed, 200+ MB). The compressed
#    version lives at assets/demo.mp4 and IS tracked.
/DEMO_FoW.mp4

# -- Personal brainstorm doc (Italian, design notes, not for public) -------
fallout_multiplayer_project_brainstorm.md

# -- Internal Italian dev docs (kept locally, not for public consumption) ---
fw_native/docs/B5_*.md
fw_native/docs/DEVIAZIONE_*.md
fw_native/docs/PIVOT_*.md
fw_native/docs/tools-da-usare.md

# -- Legacy Python net code (Italian, superseded by net/server/ + net/client/)
net/legacy/

# -- Frida one-shot debug scripts with hardcoded personal paths -------------
frida/spawn_*.py

# -- IDA Python analysis scripts (regenerable; outputs the public dossiers) -
# Public-facing dossiers kept: re/M8P{1,2,3}_*.txt + re/M8_strategic_decision.txt
re/_*.py
re/_*.txt
re/actor_hijack_*.txt
re/addiem_*.txt
re/angr_*.py
re/angr_*.txt
re/bsgraphics_*.txt
re/bslsp_*.txt
re/bone_drive_*.txt
re/decomp_*.py
re/decomp_*.log
re/decomp_*.txt
re/_decomp_*.txt
re/havok_*.txt
re/havok_*.py
re/ida_*.log
re/m7_*.txt
re/_m7_*.txt
re/_m7_*.py
re/m8_*.py
re/m8_*.txt
re/m8p3_*.py
re/_m8p*_raw*.log
re/nif_*.txt
re/render_*.txt
re/render_*.py
re/scene_*.txt
re/skin_*.txt
re/skin_*.py
re/stradaB_*.txt
re/stradaB_*.py
re/_strada*.py
re/world_*.txt
re/world_*.py
re/worldtocam_*.txt
re/writer_*.txt
re/_quick_*.txt
re/_triton_*.txt
re/_bgsm_*.py
re/_bgsm_*.txt
re/_bone_*.py
re/_check_*.py
re/_find_*.py
re/_anim_*.py
re/_verify_*.py
re/Fallout4.exe_angr_rtdb/

# Note: tracked .md files (root README, CHANGELOG, fw_native/README,
# launcher/README) are intentionally kept. Italian/internal docs are
# excluded explicitly above (fw_native/docs/B5_*.md etc.).
