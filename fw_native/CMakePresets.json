{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 25, "patch": 0 },
  "configurePresets": [
    {
      "name": "msvc-release",
      "displayName": "MSVC x64 Release (Ninja)",
      "description": "Release build for Fallout 4 NG (/arch:AVX2). Requires vcvars64 sourced.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_C_COMPILER": "cl.exe",
        "CMAKE_CXX_COMPILER": "cl.exe"
      }
    },
    {
      "name": "msvc-debug",
      "inherits": "msvc-release",
      "displayName": "MSVC x64 Debug (Ninja)",
      "binaryDir": "${sourceDir}/build-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    }
  ],
  "buildPresets": [
    { "name": "msvc-release", "configurePreset": "msvc-release" },
    { "name": "msvc-debug",   "configurePreset": "msvc-debug" }
  ]
}
